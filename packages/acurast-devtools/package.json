  },
  "devDependencies": {
    "@polkadot/keyring": "^14.0.0",
    "@polkadot/util": "^14.0.0",
    "@polkadot/wasm-crypto": "^7.3.2",
    "@types/adm-zip": "^0.5.7",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
