{
  "compilerOptions": {
    "strict": true,
    "target": "es2020",
    "module": "Node16",
    "moduleResolution": "Node16",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": ["src"]
}
